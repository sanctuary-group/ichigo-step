# docker-compose.prod.yml 用の変数（リポジトリ直下に .env としてコピーして編集）
#   cp .env.prod.example .env
#
# ※ ここの値は apps/api/.env の DB_* と必ず一致させること。
# ※ この .env は .gitignore 済み（コミットしない）。

# MySQL コンテナ初期化用
DB_ROOT_PASSWORD=CHANGE-ME-strong-root-password
DB_DATABASE=ichigo_step
DB_USERNAME=ichigo
DB_PASSWORD=CHANGE-ME-strong-db-password
