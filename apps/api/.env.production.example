APP_NAME=ichigo-step
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://message.one-step-studio.jp

# 運営側 管理画面の秘密パス（必ず推測困難な値に変更）
ADMIN_PATH=ops-CHANGE-ME

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP
APP_TIMEZONE=Asia/Tokyo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# LINE Webhook / LIFF / QR の公開ベース URL（本番ドメイン）
LINE_PUBLIC_BASE_URL=https://message.one-step-studio.jp

# --- DB（docker-compose.prod.yml の値と必ず一致させる）---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ichigo_step
DB_USERNAME=ichigo
DB_PASSWORD=CHANGE-ME-strong-db-password

# --- セッション（HTTPS 本番）---
# SESSION_DOMAIN は空のまま（message.one-step-studio.jp に限定。先頭ドット付き禁止）
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- メール（Brevo SMTP リレー）---
# Brevo 管理画面 → SMTP & API → SMTP で発行した値を入れる:
#   MAIL_USERNAME = Brevo に表示される「ログイン」(アカウントのメールアドレス)
#   MAIL_PASSWORD = 発行した SMTP キー（アカウントのログインPWではない）
# 送信元ドメイン(one-step-studio.jp)は Brevo の Domains で認証(SPF/DKIM)しておくこと。
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@one-step-studio.jp"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
